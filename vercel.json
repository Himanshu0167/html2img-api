{
    "builds": [
        {
            "src": "*.php",
            "use": "vercel-php@0.7.1"
        }
    ],
    "routes": [
        {
            "src": "/test\\.html",
            "dest": "/test.html"
        },
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ]
}
